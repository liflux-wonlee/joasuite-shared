{
  "name": "@joasuite/shared-ui",
  "version": "0.1.1",
  "description": "Shared UI, server functions, and i18n for JoaSuite apps (JoaBooks, JoaSOP, JoaOffice, JoaApproval, JoaCRM).",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./i18n/en": "./src/i18n/en.json",
    "./i18n/ko": "./src/i18n/ko.json",
    "./i18n/zh": "./src/i18n/zh.json",
    "./i18n/es": "./src/i18n/es.json",
    "./i18n/vi": "./src/i18n/vi.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "tsup"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-start": "^1.167.0",
    "i18next": "^26.0.0",
    "lucide-react": "^0.575.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.0.0",
    "sonner": "^2.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }


  
}
